# AutoTrade live_cycle.py 실행용 예시 .env 파일
# 이 파일을 저장소 루트의 `.env`로 복사한 뒤 값만 바꿔서 사용합니다.
#
# 예시:
# cp docs/live_cycle.env.example .env
# python tools/live_cycle.py

# 브로커 환경: 내부 시뮬레이터는 `paper`, 실브로커 연동은 `live`
AUTOTRADE_BROKER_ENV=paper
AUTOTRADE_BROKER_PROVIDER=koreainvestment

# paper 환경에서도 현재 설정 로더상 비어 있지 않은 값이 필요합니다.
AUTOTRADE_BROKER_API_KEY=demo-key
AUTOTRADE_BROKER_API_SECRET=demo-secret
AUTOTRADE_BROKER_ACCOUNT=12345678-01

# 자동매매 대상 종목 코드
AUTOTRADE_TARGET_SYMBOLS=069500,357870

# 운영 산출물과 바 CSV 기본 경로
AUTOTRADE_LOG_DIR=./logs

# 기본 리스크 제한
AUTOTRADE_RISK_MAX_POSITION_WEIGHT=0.2
AUTOTRADE_RISK_MAX_CONCURRENT_HOLDINGS=3
AUTOTRADE_RISK_TRADING_HALTED=false
AUTOTRADE_RISK_EMERGENCY_STOP=false
AUTOTRADE_RISK_CANCEL_UNFILLED_ON_MARKET_CLOSE=true

# 텔레그램 알림 설정
# 비활성화 시 아래 token/chat id 값은 비워두거나 제거해도 됩니다.
AUTOTRADE_TELEGRAM_ENABLED=false
AUTOTRADE_TELEGRAM_BOT_TOKEN=
AUTOTRADE_TELEGRAM_CHAT_ID=

# 선택값: warning/error만 별도 채널로 분리하고 나머지는 기본 chat id로 보냅니다.
AUTOTRADE_TELEGRAM_WARNING_CHAT_ID=
AUTOTRADE_TELEGRAM_ERROR_CHAT_ID=

# 선택값: 429/5xx/네트워크 오류 시 재시도 정책
AUTOTRADE_TELEGRAM_MAX_RETRIES=3
AUTOTRADE_TELEGRAM_TIMEOUT_SECONDS=10
